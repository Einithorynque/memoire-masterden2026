	keywords = {Typologie de cartographies, Manipulation de l'information, Histoire de la cartographie},
	file = {Snapshot:C\:\\Users\\frele\\Zotero\\storage\\TX4SW42A\\Plan_du_métro_de_Londres.html:text/html},
}

